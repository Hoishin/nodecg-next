{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"plugins": ["typescript", "unicorn", "oxc"],
	"categories": {
		"correctness": "error",
		"nursery": "error"
	},
	"rules": {
		"no-undef": "off",
		"max-lines-per-function": "off"
	},
	"env": {
		"builtin": true
	},
	"options": {
		"typeAware": true
	}
}
